{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/Doc/(.*)", "destination": "/Doc/$1" },
    { "source": "/images/(.*)", "destination": "/images/$1" },
    { "source": "/ialab-resources/(.*)", "destination": "/ialab-resources/$1" },
    {
      "source": "/api/:path*",
      "destination": "https://edutechlife-backend.onrender.com/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
